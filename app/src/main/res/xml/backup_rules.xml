<?xml version="1.0" encoding="utf-8"?>
<!-- Disable backups. -->
<data-extraction-rules>
    <cloud-backup disableIfNoEncryptionCapabilities="true">
        <exclude domain="root" path="." />
    </cloud-backup>

    <device-transfer>
        <exclude domain="root" path="." />
    </device-transfer>
</data-extraction-rules>
