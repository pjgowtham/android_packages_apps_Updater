<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/SettingsLibEntityHeader"
    android:paddingVertical="0dp"
    android:orientation="vertical">

    <LinearLayout
        style="@style/SettingsLibEntityHeaderContent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/check_updates_button"
            style="@style/SettingsLibButtonStyle.Expressive.Outline"
            android:layout_width="match_parent"
            android:text="@string/check_for_updates" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="@dimen/settingslib_expressive_space_small1"
            android:gravity="end"
            android:orientation="horizontal">

            <TextView
                style="@style/TextAppearance.EntityHeaderSummary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/settingslib_expressive_space_extrasmall4"
                android:text="@string/header_last_updates_check_label" />

            <TextView
                android:id="@+id/last_check_date"
                style="@style/TextAppearance.EntityHeaderSummary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/settingslib_expressive_space_extrasmall4"
                tools:text="February 1, 2026" />

            <TextView
                android:id="@+id/last_check_time"
                style="@style/TextAppearance.EntityHeaderSummary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="12:00 PM" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
