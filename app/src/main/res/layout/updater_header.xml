<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/SettingsLibEntityHeaderContent"
    android:layout_width="match_parent"
    android:background="@drawable/header_background"
    android:gravity="center"
    android:orientation="vertical">

    <ImageView
        android:id="@+id/header_icon"
        style="@style/SettingsLibEntityHeaderIcon"
        android:layout_marginTop="@dimen/settingslib_expressive_space_small1"
        android:layout_marginBottom="@dimen/settingslib_expressive_space_small1"
        tools:src="@drawable/settingslib_expressive_icon_level_low" />

    <TextView
        android:id="@+id/header_build_date"
        style="@style/TextAppearance.EntityHeaderTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:text="April 1, 2025" />

    <TextView
        android:id="@+id/header_build_version"
        style="@style/TextAppearance.EntityHeaderSummary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:text="Android 16\n|\nLineageOS 23.2" />

    <TextView
        android:id="@+id/header_security_patch_level"
        style="@style/TextAppearance.EntityHeaderSummary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:text="Android security update:\nFebruary 5, 2025" />

    <TextView
        android:id="@+id/header_last_check"
        style="@style/TextAppearance.EntityHeaderSummary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:text="Last checked:\nApril 1, 2026 12:00 PM"
        tools:textColor="@color/settingslib_colorBackgroundLevel_low"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/settingslib_expressive_space_small1"
        android:layout_marginEnd="@dimen/settingslib_expressive_space_small1"
        android:gravity="center"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/show_changelog_button"
            style="@style/SettingsLibButtonStyle.Expressive.Tonal"
            android:layout_width="wrap_content"
            android:layout_margin="@dimen/settingslib_expressive_space_small1"
            android:layout_weight="1"
            android:text="@string/show_changelog" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/report_issue_button"
            style="@style/SettingsLibButtonStyle.Expressive.Tonal"
            android:layout_width="wrap_content"
            android:layout_margin="@dimen/settingslib_expressive_space_small1"
            android:layout_weight="1"
            android:text="@string/report_issues" />

    </LinearLayout>
</LinearLayout>
