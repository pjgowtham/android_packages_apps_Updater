<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/SettingsLibEntityHeaderContent"
    android:layout_width="match_parent"
    android:background="@drawable/wallpaper_picker_entry_background"
    android:gravity="center"
    android:orientation="vertical">

    <ImageView
        android:id="@+id/entity_header_icon"
        style="@style/SettingsLibEntityHeaderIcon"
        android:layout_marginTop="@dimen/settingslib_expressive_space_extrasmall4"
        android:layout_marginBottom="@dimen/settingslib_expressive_space_extrasmall4"
        tools:src="@drawable/ic_verified" />

    <TextView
        android:id="@+id/entity_header_title"
        style="@style/TextAppearance.EntityHeaderTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:text="April 1, 2025" />

    <TextView
        android:id="@+id/entity_header_summary"
        style="@style/TextAppearance.EntityHeaderSummary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:text="Android 16\n|\nLineageOS 23.2" />

    <TextView
        android:id="@+id/entity_header_second_summary"
        style="@style/TextAppearance.EntityHeaderSummary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:text="Last checked: April 1, 2024 12:00 PM" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/show_changelog_button"
        style="@style/SettingsLibButtonStyle.Expressive.Filled"
        android:layout_marginTop="@dimen/settingslib_expressive_space_extrasmall4"
        android:layout_marginBottom="@dimen/settingslib_expressive_space_extrasmall4"
        android:text="@string/menu_show_changelog" />

</LinearLayout>