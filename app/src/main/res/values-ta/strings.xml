    <string name="blocked_update_dialog_title">இற்றை தடுக்கப்பட்டது</string>
    <string name="blocked_update_dialog_message">இந்த இற்றையினை இற்றையம் வழியாக நிறுவ இயலாது. கூடுதல் விவரங்களுக்கு <xliff:g id="info_url">%1$s</xliff:g> என்பதைப் பார்க்கவும்.</string>
