    <string name="apply_update_dialog_title">இற்றையை நிறுவுக</string>
    <string name="apply_update_dialog_message">நீங்கள் <xliff:g id="update_name">%1$s</xliff:g> என்பதை நிறுவ உள்ளீர்.\n\nநீங்கள் <xliff:g id="ok">%2$s</xliff:g> என்பதை அழுத்தினால், இற்றையை நிறுவுவதற்காகக் கருவி மீட்புப் பயன்முறையில் தானாகவே மீண்டும் தொடங்கும்.\n\nகுறிப்பு: இதற்குப் பொருத்தமான மீட்பு மென்பொருள் தேவை. இல்லையெனில், இற்றையை நீங்களே நேரடியாக நிறுவ வேண்டியிருக்கும்.</string>
    <string name="apply_update_dialog_message_ab">நீங்கள் <xliff:g id="update_name">%1$s</xliff:g> என்பதை நிறுவ உள்ளீர்.\n\nநீங்கள் <xliff:g id="ok">%2$s</xliff:g> என்பதை அழுத்தினால், இற்றை நிறுவல் பின்னணியில் தொடங்கும்.\n\nநிறுவல் முடிந்ததும், கருவியை மீண்டும் தொடங்க உங்களுக்கு அறிவிக்கப்படும்.</string>
