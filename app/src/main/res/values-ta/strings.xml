    <string name="update_over_metered_network_title">எச்சரிக்கை</string>
    <string name="update_over_metered_network_message">அளவிடப்பட்ட பிணையத்தைப் பயன்படுத்தி இற்றைத் தொகுப்பைத் தரவிறக்கப் போகிறீர். இஃது அதிக தரவுப் பயன்பாட்டிற்கு வழிவகுக்கும். தொடர வேண்டுமா?</string>
