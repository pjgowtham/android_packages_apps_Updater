<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_container"
    style="@style/SettingsLibEntityHeader"
    android:layout_height="match_parent"
    android:baselineAligned="false"
    android:orientation="horizontal"
    app:layout_behavior="@string/appbar_scrolling_view_behavior">

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <include layout="@layout/header" />

            <include
                android:id="@+id/network_warning_card"
                layout="@layout/settingslib_expressive_preference_card"
                android:visibility="gone" />

            <FrameLayout
                android:id="@+id/quick_actions_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/settingslib_expressive_space_small1" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <Space
        android:layout_width="@dimen/settingslib_expressive_space_small1"
        android:layout_height="match_parent" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <include layout="@layout/check_updates_content" />

            <FrameLayout
                android:id="@+id/updates_list_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:descendantFocusability="afterDescendants"
                android:focusable="true"
                android:nextFocusLeft="@+id/show_changelog_button" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
